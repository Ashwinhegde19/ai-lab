# Environment variables for the Personal AI Lab
# Copy to .env and fill in your keys

# ---- Hugging Face ----
HF_TOKEN=hf_your_token_here

# ---- Frontier model APIs (for judge + comparison) ----
OPENAI_API_KEY=sk-your-key
# Optional alternatives:
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=

# ---- Modal (compute) ----
MODAL_TOKEN_ID=ak-your-id
MODAL_TOKEN_SECRET=as-your-secret

# ---- Langfuse (observability, station 12) ----
LANGFUSE_SECRET_KEY=lf_sk_your_secret
LANGFUSE_PUBLIC_KEY=lf_pk_your_public
LANGFUSE_HOST=http://localhost:3000

# ---- vLLM server (station 05) ----
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ---- Optional: Tavily for web search in RAG station ----
TAVILY_API_KEY=
